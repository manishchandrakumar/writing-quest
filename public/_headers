# Cloudflare Pages headers — applied automatically on deploy
# https://developers.cloudflare.com/pages/configuration/headers/

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Astro emits content-hashed filenames under /assets — safe to cache forever
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Worksheet blanks don't change once printed
/worksheets/*
  Cache-Control: public, max-age=604800, immutable

# Public photo gallery (v2) — same logic; canonical filenames are immutable
/photos/*
  Cache-Control: public, max-age=2592000

# HTML pages — short cache so a verified review lands quickly after deploy
/*.html
  Cache-Control: public, max-age=300, must-revalidate
